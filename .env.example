# --- API server ---
PORT=3000
NODE_ENV=development

# --- Supabase (reserved for upcoming Z2.1 merchant store) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Solana ---
# devnet | testnet | mainnet-beta | localnet
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_COMMITMENT=confirmed
# Devnet USDC (Circle): 4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
SOLANA_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# base58 (Phantom export) or JSON array (Solana CLI). Funds ATA rent + memo tx (~0.002 SOL each).
SOLANA_FEE_PAYER_SECRET=
ZETTAPAY_MEMO_NAMESPACE=zettapay:merchant_register:v1

# --- Fabric integration tokens ---
# Gerar com: openssl rand -hex 32
FABRIC_INGEST_TOKEN=
# Webhook n8n outbound (hipotese.approved, premissas.updated). Opcional.
N8N_WEBHOOK_URL=
# Secret do webhook Vercel (Project Settings > Webhooks > Secret).
VERCEL_WEBHOOK_SECRET=

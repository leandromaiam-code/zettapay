# ZettaPay API — Solana connection service
PORT=3001

# Solana network (devnet | testnet | mainnet-beta)
SOLANA_NETWORK=devnet

# RPC endpoint. Defaults to Solana Labs' public devnet node when unset.
# Use a private RPC (Helius / QuickNode / Triton) in staging and production.
SOLANA_RPC_URL=https://api.devnet.solana.com

# Exponential-backoff retry policy for transient RPC failures.
RPC_MAX_RETRIES=5
RPC_INITIAL_BACKOFF_MS=250
RPC_MAX_BACKOFF_MS=4000

# Faucet helper hard cap per airdrop (lamports). Default = 2 SOL.
FAUCET_MAX_AIRDROP_LAMPORTS=2000000000

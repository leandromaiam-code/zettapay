# --- ZettaPay API server ---
PORT=4000
NODE_ENV=development

# Z40 — Email verification via Supabase Auth OTP.
# Required for /api/merchants/register + /api/merchants/verify. Without these,
# signup endpoints respond 503 verification_disabled and the public /signup
# flow cannot mint credentials.
#
# Where to find these in the Supabase Dashboard:
#   Project Settings → API → Project URL  → SUPABASE_URL
#   Project Settings → API → Project API keys → anon public → SUPABASE_ANON_KEY
#   Project Settings → API → Project API keys → service_role → SUPABASE_SERVICE_ROLE_KEY
#
# Service role is OPTIONAL — when present, /register also rejects emails that
# are already confirmed (409 merchant_already_active). When absent, the only
# guard is Supabase Auth's own dedupe.
#
# Dashboard config required for OTP delivery (do once per project):
#   Authentication → Providers → Email: enable, Confirm email = on,
#       OTP enabled = yes (not magic link), OTP length = 6, OTP expiry = 1800s
#   Authentication → Email Templates → Magic Link:
#       Subject: "Your ZettaPay verification code"
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Z40 — Shared secret used to deterministically derive merchant ids from
# verified emails. Defaults to a dev value when unset; rotate this per env to
# avoid id collisions between staging and prod. Loss = re-derived merchant ids
# for every active merchant, so handle like a long-lived signing key.
ZETTAPAY_MERCHANT_ID_SECRET=

# Solana cluster: devnet | testnet | mainnet-beta | localnet
# Switch to mainnet-beta in production. Defaults to devnet.
SOLANA_NETWORK=devnet
# Optional: overrides the RPC endpoint. Defaults to the public cluster URL for SOLANA_NETWORK.
SOLANA_RPC_URL=https://api.devnet.solana.com
# Commitment level for tx confirmation: processed | confirmed | finalized
SOLANA_COMMITMENT=confirmed

# USDC SPL token mint (devnet)
USDC_MINT_ADDRESS=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# F2.5 — Secret do webhook Vercel (Project Settings > Webhooks > Secret).
# Captura previews automáticos por mission via /api/vercel/webhook.
VERCEL_WEBHOOK_SECRET=

# Z5.2 — MoonPay onramp webhook (incoming).
# Shared secret usado para validar HMAC-SHA256 do header Moonpay-Signature-V2.
# Sem este secret, POST /onramp/webhook responde 503 onramp_disabled.
MOONPAY_WEBHOOK_SECRET=

# Webhook do merchant (outbound) — recebe payment.confirmed quando onramp completa.
# Opcional: se vazio, o handler grava no PaymentLog mas não notifica externamente.
MERCHANT_WEBHOOK_URL=
MERCHANT_WEBHOOK_SECRET=

# Z15.1 — Shopify app integration. Sem estes 3 vars, /shopify/install e
# /shopify/callback retornam 503; /shopify/snippet/<merchant>.liquid funciona
# independentemente para que o merchant possa testar o snippet localmente.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
# Default: read_orders,write_script_tags. Não inclua escopos PII sem necessidade.
SHOPIFY_SCOPES=

# Z21.1 — Sumsub KYC integration (merchant onboarding, audit-prep).
# Sem estes 3 vars, /merchants/:id/kyc/* respondem 503 kyc_disabled.
# SUMSUB_BASE_URL é opcional (default https://api.sumsub.com).
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_WEBHOOK_SECRET=
SUMSUB_BASE_URL=

# Z22.3 — Treasury / insurance reserve admin.
# /treasury/reserve/* are admin endpoints gated by ZETTAPAY_TREASURY_ADMIN_KEY.
# Without a key (min 24 chars) the routes reject every call with config_error,
# so accidentally launching mainnet without setting it cannot expose them.
# RESERVE_RATIO is the % of completed TPV the reserve targets (default 0.05 = 5%).
ZETTAPAY_TREASURY_ADMIN_KEY=
ZETTAPAY_TREASURY_RESERVE_RATIO=
# Z22.1 — Beta launch protocol.
# Disabled in dev/test by default. Production rollout flips BETA_MODE_ENABLED=true,
# pins the curated 10-merchant cohort, and enforces a $10k per-merchant cap until
# the window expires (launchAt + durationDays).
BETA_MODE_ENABLED=false
BETA_LAUNCH_AT=
BETA_DURATION_DAYS=30
BETA_MERCHANT_CAP_USDC=10000
BETA_MAX_MERCHANTS=10
# Comma-separated merchant ids permitted to transact while beta is active.
BETA_ALLOWED_MERCHANTS=

# Z13.2 — OFAC wallet blacklist extension.
# The seed list (Tornado Cash + cyber sanctions) ships baked into the build.
# Use this var to extend it at deploy time without a code change. Format is
# comma-separated entries, each either "address" or "address|reason".
# Example: OFAC_BLACKLIST_EXTRA=ADDR1|North Korea Lazarus,ADDR2
OFAC_BLACKLIST_EXTRA=

# Z18.2 — OpenTelemetry distributed tracing.
# Sem nenhuma variável OTEL_*, tracing fica em modo no-op (nenhum span exportado).
# Set OTEL_TRACES_EXPORTER=console em dev para ver spans no stdout.
# Set OTEL_EXPORTER_OTLP_ENDPOINT=https://collector.example.com em prod.
OTEL_SDK_DISABLED=
OTEL_TRACES_EXPORTER=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=
# Z18.1 — Sentry (error tracking + performance monitoring + release tracking).
# Sem SENTRY_DSN, o SDK não envia eventos (no-op total).
SENTRY_DSN=
# Override opcional do environment label. Default: VERCEL_ENV ou NODE_ENV.
SENTRY_ENVIRONMENT=
# Release identifier. Default: VERCEL_GIT_COMMIT_SHA injetado pela Vercel build.
SENTRY_RELEASE=
# Sampling de transações de performance (0.0 - 1.0). Default: 0.1 em prod, 0 fora.
SENTRY_TRACES_SAMPLE_RATE=
# Profiling sample rate (0.0 - 1.0). Default: 0.
SENTRY_PROFILES_SAMPLE_RATE=

# Z18.5 — synthetic monitor (native, no Checkly dep).
# Probes the live /pay endpoint on a fixed cadence so an outage is detected
# before merchants notice. Without SYNTHETIC_MONITOR_TARGET_URL set the
# cron-worker logs synthetic_monitor.disabled and skips boot.
# Probe runs `GET <target>` by default (no side effects). Set METHOD=POST +
# POST_BODY to exercise the full payment path against a test merchant.
SYNTHETIC_MONITOR_TARGET_URL=
# Cadence in ms. Floored to 5_000 to avoid runaway probes. Default 60_000.
SYNTHETIC_MONITOR_INTERVAL_MS=
# Per-probe wallclock budget. Default 5_000.
SYNTHETIC_MONITOR_TIMEOUT_MS=
# Latency threshold in ms — a successful but slower probe is flagged as 'slow'.
# Default 2_000 (matches Z18.5 SLA target).
SYNTHETIC_MONITOR_LATENCY_THRESHOLD_MS=
# Consecutive failures required before the alarm is raised. Default 2.
SYNTHETIC_MONITOR_ALERT_AFTER_FAILURES=
# Probe HTTP method: GET or POST. Default GET.
SYNTHETIC_MONITOR_METHOD=
# JSON body sent when METHOD=POST. Must be a JSON object string.
SYNTHETIC_MONITOR_POST_BODY=
# Hard kill switch — set to "false" to disable even when TARGET_URL is set.
SYNTHETIC_MONITOR_ENABLED=
# Z12.2 — Pix payout (USDC -> BRL) para MEI brasileiro.
# Cada provider é independentemente opcional. Sem credenciais o endpoint
# /merchants/:id/settlement/pix fica oculto. Suporta Bitpreço e Transfero.
# PIX_ENV é fallback compartilhado quando o provider não define o seu próprio.
PIX_ENV=sandbox
BITPRECO_API_KEY=
BITPRECO_ENV=
BITPRECO_BASE_URL=
TRANSFERO_API_KEY=
TRANSFERO_ENV=
TRANSFERO_BASE_URL=
# Z11.3 — Cross-chain bridge (Wormhole/CCTP) attestation client.
# Set BRIDGE_ATTESTATION_ENV to "sandbox" or "production" to mount /bridge/*.
# Sandbox = Circle iris-api-sandbox.circle.com (testnet domains).
# Production = iris-api.circle.com (mainnet). Without this var, /bridge/* is
# not mounted at all so dev environments don't expose endpoints that 502.
BRIDGE_ATTESTATION_ENV=
BRIDGE_ATTESTATION_BASE_URL=

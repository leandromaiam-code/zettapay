# --- ZettaPay API server ---
PORT=4000
NODE_ENV=development

# Solana RPC (devnet by default)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_COMMITMENT=confirmed

# USDC SPL token mint (devnet)
USDC_MINT_ADDRESS=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# F2.5 — Secret do webhook Vercel (Project Settings > Webhooks > Secret).
# Captura previews automáticos por mission via /api/vercel/webhook.
VERCEL_WEBHOOK_SECRET=

# MoonPay onramp (card → USDC). Sem MOONPAY_API_KEY o /onramp responde 503.
# Use pk_test_* em sandbox e pk_live_* em produção.
MOONPAY_API_KEY=
# sandbox (default) → https://buy-sandbox.moonpay.com  |  production → https://buy.moonpay.com
MOONPAY_ENV=sandbox
# Crypto code default (e.g. usdc_sol, usdc, eth). Override por requisição também.
MOONPAY_DEFAULT_CURRENCY=usdc_sol

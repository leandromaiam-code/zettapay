# --- ZettaPay API server ---
PORT=4000
NODE_ENV=development

# Solana RPC (devnet by default)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_COMMITMENT=confirmed

# USDC SPL token mint (devnet)
USDC_MINT_ADDRESS=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Base58 secret key for the facilitator/payer keypair (devnet only — never use mainnet keys here).
# Used to sign SPL transfers from the payer ATA. Required by POST /pay.
PAYER_SECRET_KEY=

# SQLite database file path
DATABASE_PATH=./data/zettapay.db

# Optional: outbound webhook target for payment events
WEBHOOK_DISPATCH_URL=

# --- ZettaPay API server ---
PORT=4000
NODE_ENV=development

# Solana cluster: devnet | testnet | mainnet-beta | localnet
# Switch to mainnet-beta in production. Defaults to devnet.
SOLANA_NETWORK=devnet
# Optional: overrides the RPC endpoint. Defaults to the public cluster URL for SOLANA_NETWORK.
SOLANA_RPC_URL=https://api.devnet.solana.com
# Commitment level for tx confirmation: processed | confirmed | finalized
SOLANA_COMMITMENT=confirmed

# USDC SPL token mint (devnet)
USDC_MINT_ADDRESS=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# F2.5 — Secret do webhook Vercel (Project Settings > Webhooks > Secret).
# Captura previews automáticos por mission via /api/vercel/webhook.
VERCEL_WEBHOOK_SECRET=

# Z5.2 — MoonPay onramp webhook (incoming).
# Shared secret usado para validar HMAC-SHA256 do header Moonpay-Signature-V2.
# Sem este secret, POST /onramp/webhook responde 503 onramp_disabled.
MOONPAY_WEBHOOK_SECRET=

# Webhook do merchant (outbound) — recebe payment.confirmed quando onramp completa.
# Opcional: se vazio, o handler grava no PaymentLog mas não notifica externamente.
MERCHANT_WEBHOOK_URL=
MERCHANT_WEBHOOK_SECRET=

# Z15.1 — Shopify app integration. Sem estes 3 vars, /shopify/install e
# /shopify/callback retornam 503; /shopify/snippet/<merchant>.liquid funciona
# independentemente para que o merchant possa testar o snippet localmente.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
# Default: read_orders,write_script_tags. Não inclua escopos PII sem necessidade.
SHOPIFY_SCOPES=

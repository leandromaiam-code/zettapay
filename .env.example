NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Token aleatório para autenticar n8n em /api/n8n/ingest
# Gerar com: openssl rand -hex 32
FABRIC_INGEST_TOKEN=

# URL do webhook n8n para receber eventos outbound (hipotese.approved, premissas.updated)
# Opcional na V0 — se vazio, só loga
N8N_WEBHOOK_URL=

# F2.5 — Secret do webhook Vercel (Project Settings > Webhooks > Secret).
# Captura previews automáticos por mission via /api/vercel/webhook.
VERCEL_WEBHOOK_SECRET=

{
  "name": "@zettapay/twitter-bot",
  "version": "0.1.0",
  "private": true,
  "description": "ZettaPay Twitter/X bot — auto-posts protocol milestones (TPV thresholds, new merchants, weekly devotion stats).",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "tick": "tsx src/index.ts --once",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.18"
  }
}

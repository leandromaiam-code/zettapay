# X (Twitter) API — OAuth 1.0a User Context credentials.
# Generate at https://developer.x.com — the project must have "Read and write"
# permissions and you must have a User Access Token (not just App-only).
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ZettaPay platform stats source. Defaults to the public production API.
# The bot calls GET /v1/public/stats which exposes only aggregate non-sensitive
# metrics (lifetime TPV, merchant count, subscriptions). No API key required.
ZETTAPAY_API_BASE=https://api.zettapay.io

# Poll interval (seconds). Bot wakes up, checks stats, posts any tripped
# milestone, sleeps. 600s (10min) is a sensible default — milestones are
# coarse-grained and X has rate limits.
POLL_INTERVAL_SECONDS=600

# Where to persist last-posted milestone state across restarts. Keep this
# stable so the bot does not double-post after a redeploy.
STATE_FILE=./state.json

# When true, the bot logs the tweet it WOULD post but does not call the X API.
# Set to true for staging / first deploy. Flip to false to go live.
DRY_RUN=true

# Set to a non-empty string to skip the weekly devotion digest entirely
# (useful while we tune the cadence). Format: "weekday,UTC-hour" e.g. "1,15"
# means Monday 15:00 UTC.
WEEKLY_DIGEST_AT=1,15

# Pino log level: trace | debug | info | warn | error
LOG_LEVEL=info

# ZettaPay Discord bot — required env vars.
# Copy to .env and fill in. Never commit .env.

# Bot token from https://discord.com/developers/applications
# Ops note: rotate quarterly and on any suspected leak. The bot exits if missing.
DISCORD_TOKEN=

# Application client ID (also from the developer portal).
# Used by `npm run register` to publish slash commands.
DISCORD_CLIENT_ID=

# Guild (server) ID. Right-click the server icon in Discord with developer mode
# on -> "Copy Server ID". Slash commands register per-guild for instant updates.
DISCORD_GUILD_ID=

# Channel ID for the welcome embed. Right-click #welcome -> "Copy Channel ID".
# If empty, the bot DMs the welcome embed to the new member instead.
DISCORD_WELCOME_CHANNEL_ID=

# Role names. Must match `server-config.json`. Edit only if you renamed roles.
DISCORD_DEFAULT_ROLE=Member
DISCORD_SELF_ASSIGNABLE_ROLES=Merchant,Agent Builder,Developer

# Pino log level (trace|debug|info|warn|error). Default: info.
LOG_LEVEL=info

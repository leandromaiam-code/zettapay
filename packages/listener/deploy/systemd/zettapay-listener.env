# @zettapay/listener — systemd EnvironmentFile template.
# Install at /etc/zettapay/listener.env with mode 0640 (root:zettapay).
# Never commit a real, populated copy.

# Required ----------------------------------------------------------------
MERCHANT_WEBHOOK_URL=https://your.shop/zettapay/webhook
# Generate one strong value, e.g. with `openssl rand -hex 32`, and prefix it with `whsec_`.
MERCHANT_WEBHOOK_SECRET=REPLACE_ME

# Storage adapter (json | sqlite | supabase | postgres). Default: json.
STORAGE=json
ZETTAPAY_DATA_DIR=/var/lib/zettapay/data

# Health probe -----------------------------------------------------------
HEALTH_PORT=8787

# Optional ----------------------------------------------------------------
# MERCHANT_ID=
# MEMPOOL_WS_URL=wss://mempool.space/api/v1/ws
# MEMPOOL_REST_URL=https://mempool.space/api

# SQLite adapter
# ZETTAPAY_SQLITE_FILE=/var/lib/zettapay/data/zettapay.db

# Supabase adapter
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=

# Postgres adapter
# PGHOST=
# PGUSER=
# PGPASSWORD=
# PGDATABASE=
# PGSSLMODE=require

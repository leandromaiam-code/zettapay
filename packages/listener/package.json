{
  "name": "@zettapay/listener",
  "version": "0.1.2",
  "description": "Self-hosted, non-custodial BTC payment listener. Watches BIP-84 addresses derived from the merchant xpub, dispatches HMAC-signed webhooks. No phone-home.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "zettapay-listener": "./dist/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "Dockerfile"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "start": "node ./dist/main.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@noble/hashes": "^1.8.0",
    "@scure/base": "^1.2.6",
    "@scure/bip32": "^1.7.0",
    "proper-lockfile": "^4.1.2",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "*",
    "better-sqlite3": "*",
    "pg": "*"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": { "optional": true },
    "better-sqlite3": { "optional": true },
    "pg": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/proper-lockfile": "^4.1.4",
    "@types/ws": "^8.5.13",
    "better-sqlite3": "^11.10.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/leandromaiam-code/zettapay.git",
    "directory": "packages/listener"
  },
  "homepage": "https://github.com/leandromaiam-code/zettapay/tree/main/packages/listener#readme",
  "keywords": [
    "bitcoin",
    "btc",
    "payments",
    "webhooks",
    "self-hosted",
    "non-custodial",
    "mempool.space",
    "zettapay"
  ]
}

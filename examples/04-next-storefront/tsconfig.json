{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "lib": ["dom", "dom.iterable", "esnext"],
    "noEmit": true,
    "plugins": [{ "name": "next" }]
  },
  "include": ["app/**/*.ts", "app/**/*.tsx", "next-env.d.ts"],
  "exclude": ["node_modules"]
}

{
  "name": "zettapay",
  "version": "0.0.0",
  "private": true,
  "description": "ZettaPay — universal Solana payment protocol monorepo",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",

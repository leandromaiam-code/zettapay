{
  "name": "zettapay",
  "version": "0.0.0",
  "private": true,
  "description": "ZettaPay — universal Solana payment protocol monorepo",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev": "npm run dev --workspace @zettapay/api",
    "vercel-build": "echo 'serverless functions auto-detected from /api'",
    "clean": "rm -rf packages/*/dist"
  },
  "devDependencies": {
    "@vercel/node": "^3.2.24"
  },
  "engines": {
    "node": ">=18.18"
  }
}

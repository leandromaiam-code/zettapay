{
  "name": "zettapay",
  "version": "0.0.0",
  "private": true,
  "description": "ZettaPay — universal Solana payment protocol monorepo",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev": "npm run dev --workspace @zettapay/api",
    "vercel-build": "echo 'serverless functions auto-detected from /api'",
    "clean": "rm -rf packages/*/dist",
    "docs:dev": "npx -y mint@latest dev --path docs",
    "docs:check": "npx -y mint@latest broken-links --path docs",
    "openapi:export": "npm run -w @zettapay/api build && node scripts/export-openapi.mjs",
    "sdk:generate": "npm run openapi:export && bash scripts/generate-sdks.sh",
    "audit:static-rust": "bash scripts/static-analysis-rust.sh",
    "smoke:devnet": "tsx scripts/smoke-devnet.ts",
    "stress:construction:z28-4": "tsx scripts/stress-construction-z28-4.ts",
    "beta:devnet:z28-1": "tsx scripts/beta-devnet-z28-1.ts",
    "beta:mainnet:onboard": "tsx scripts/beta-mainnet-z30-2-onboard.ts",
    "beta:mainnet:digest": "tsx scripts/beta-mainnet-z30-2-digest.ts"
  },
  "devDependencies": {
    "@vercel/node": "^3.2.24"
  },
  "engines": {
    "node": ">=18.18"
  },
  "dependencies": {
    "@noble/curves": "^1.6.0",
    "@scure/bip32": "^1.7.0",
    "@scure/bip39": "^1.4.0",
    "@scure/btc-signer": "^1.5.0",
    "@sentry/node": "^10.52.0",
    "viem": "^2.21.0"
  }
}
